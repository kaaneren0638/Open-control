<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:dither="true" android:visible="true" android:shape="rectangle" android:useLevel="false">
            <solid android:color="@color/colorAccent" />
            <corners android:radius="25.0dp" />
            <size android:height="14.0dp" android:width="24.0dp" />
        </shape>
    </item>
    <item android:state_checked="false">
        <shape android:dither="true" android:visible="true" android:shape="rectangle" android:useLevel="false">
            <solid android:color="@color/mi_switch_bg_unchecked" />
            <corners android:radius="25.0dp" />
            <size android:height="14.0dp" android:width="24.0dp" />
        </shape>
    </item>
</selector>
